{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Soundscape",
  "version": "0.9.1",
  "identifier": "com.soundscape.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Soundscape",
        "width": 1920,
        "height": 1080,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data: https://freesound.org; connect-src 'self' https: blob:; media-src 'self' https: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI3MTdFMDE5OTBFRDNENzIKUldSeVBlMlFHZUFYdDVUcjVreldPRitkdHJhcnFaRGdVUWI0STg5R2w1bDZhakJoenpZWVR2Y3AK",
      "endpoints": [
        "https://github.com/JohannesKlauss/soundscape/releases/latest/download/latest.json"
      ]
    }
  }
}
