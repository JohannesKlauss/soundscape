{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "svelte": {
      "type": "remote",
      "url": "https://mcp.svelte.dev/mcp"
    },
    "tauri-mcp": {
      "type": "local",
      "command": ["tauri-mcp", "serve"],
      "enabled": true,
      "environment": {
        "TAURI_MCP_LOG_LEVEL": "info"
      }
    }
  }
}